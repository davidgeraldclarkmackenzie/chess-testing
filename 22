  const[bkr,bkc]=findKing(board,'b');
  for(let r=0;r<8;r++)for(let c=0;c<8;c++)if(board[r][c]==='wK')board[r][c]=null;
  const wkPos=(bkr>3)?[0,0]:[7,0];
