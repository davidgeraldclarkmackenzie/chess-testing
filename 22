function handleClick(r,c){
  if(gameOver)return;
  if(turn==='w'&&whiteBotIdx>=0) return; // white is a bot
  if(turn==='b'&&botIdx>=0) return;      // black is a bot
  const p=board[r][c];
  if(selected){
    const[sr,sc]=selected;
    const move=highlightMoves&&highlightMoves.find(([nr,nc])=>nr===r&&nc===c);
    if(move){
      const[nr,nc,promo]=move;
      if(drunkModeActive && color(board[sr][sc])==='b'){
        const allMoves=legalMoves(board,sr,sc,enPassant,castleRights);
        if(allMoves.length>1){
          const others=allMoves.filter(([mr,mc])=>!(mr===nr&&mc===nc));
          const drunk=others[Math.floor(Math.random()*others.length)];
          const el=pieceEls[sr+','+sc];
          if(el){
            el.style.transition='left 0.05s, top 0.05s';
            const wobble=()=>{el.style.left=(sc*sqSize+(Math.random()-0.5)*18)+'px';el.style.top=(sr*sqSize+(Math.random()-0.5)*18)+'px';};
            wobble();setTimeout(wobble,80);setTimeout(wobble,160);
            setTimeout(()=>{el.style.transition='';},250);
          }
          setTimeout(()=>{
            animateAndCommit(sr,sc,drunk[0],drunk[1],drunk[2],false,()=>{
              if(gameOver)return;
              if(Math.random()<0.5){
                const bonusMoves=allLegalMoves(board,'b',enPassant,castleRights);
                if(bonusMoves.length){
                  const bm=bonusMoves[Math.floor(Math.random()*bonusMoves.length)];
                  setTimeout(()=>animateAndCommit(bm[0],bm[1],bm[2],bm[3],bm[4],false,()=>{if(!gameOver)doBotMove();}),200);
                } else { if(!gameOver)doBotMove(); }
              } else { if(!gameOver)doBotMove(); }
            });
          },300);
          selected=null;highlightMoves=[];blockedMoves=[];
          renderSquares();
          return;
        }
      }
      animateAndCommit(sr,sc,nr,nc,promo,false,()=>{if(!gameOver)doBotMove();});
      return;
    }
    selected=null;highlightMoves=[];blockedMoves=[];
  }
  if(p&&color(p)===turn){
    selected=[r,c];
    highlightMoves=legalMoves(board,r,c,enPassant,castleRights);
    blockedMoves=[];
  }
  renderSquares();
}

