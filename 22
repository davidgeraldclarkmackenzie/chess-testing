let fp = {
  board: null,
  turn: 0,
  selected: null,
  moves: [],
  eliminated: [false,false,false,false],
  sqSize: 44,
  gameOver: false,
  botIdxs: [null, 1, 3, 5],
  teams: ['A','B','C','D'], // each player on their own team by default
