<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chess</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;900&family=Cinzel+Decorative:wght@700&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Impact&family=Courier+Prime:wght@400;700&display=swap');

:root {
  --blue-dark: #0a0fa8;
  --yellow: #f5c800;
  --yellow-dark: #c49a00;
  --cream: #f5f0d8;
  --black: #0a0a0a;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 100%; min-height: 100%;
  font-family: 'EB Garamond', Georgia, serif;
  background-color: var(--blue-dark);
  background-image: repeating-linear-gradient(45deg, transparent 0px, transparent 18px, rgba(0,0,60,0.35) 18px, rgba(0,0,60,0.35) 36px);
  display: flex; justify-content: center; align-items: flex-start;
  overflow-y: auto; padding: 20px 10px 40px;
}

#app { display: flex; flex-direction: column; align-items: center; width: fit-content; max-width: 100%; }

#header {
  width: 100%; text-align: center; padding: 10px 20px 6px;
  background: var(--blue-dark); border: 4px solid var(--yellow); border-bottom: none;
  box-shadow: 4px 4px 0 #000;
}
h1 {
  font-family: 'EB Garamond', Georgia, serif; font-size: 2rem; color: var(--yellow);
  text-transform: uppercase; letter-spacing: 3px;
  text-shadow: 3px 3px 0 #000, -1px -1px 0 #000; -webkit-text-stroke: 1px #000;
}
.header-sub {
  font-family: 'EB Garamond', Georgia, serif; font-size: 11px; color: var(--cream);
  letter-spacing: 2px; text-transform: uppercase; margin-top: 2px;
}

#status-bar {
  width: 100%; padding: 4px 12px; background: var(--cream);
  border-left: 4px solid var(--yellow); border-right: 4px solid var(--yellow);
  display: flex; justify-content: space-between; align-items: center;
  border-top: 2px solid #000; border-bottom: 2px solid #000;
  gap: 10px; min-height: 38px;
}
#status-left { display: flex; flex-direction: column; gap: 1px; flex-shrink: 0; }
#status { font-family: 'EB Garamond', Georgia, serif; font-size: 13px; letter-spacing: 0.1em; color: var(--blue-dark); text-transform: uppercase; }
#msg { font-family: 'EB Garamond', Georgia, serif; font-size: 12px; letter-spacing: 0.1em; color: #cc0000; text-transform: uppercase; text-shadow: 1px 1px 0 #ffaaaa; }

/* Chat lives inline in status bar */
#chat-inline {
  display: none;
  align-items: center;
  gap: 7px;
  flex: 1;
  justify-content: flex-end;
  overflow: hidden;
}
#chat-inline.visible { display: flex; }
#chat-inline-avatar {
  font-size: 22px;
  line-height: 1;
  flex-shrink: 0;
}
#chat-inline-bubble {
  background: var(--blue-dark);
  border: 2px solid #000;
  box-shadow: 2px 2px 0 #000;
  padding: 4px 10px;
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 13px;
  color: var(--cream);
  position: relative;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320px;
  animation: chat-pop 0.3s cubic-bezier(0.17,0.89,0.32,1.28) both;
}
#chat-inline-bubble::before {
  content: '';
  position: absolute;
  right: -9px; top: 8px;
  border: 5px solid transparent;
  border-left-color: #000;
}
#chat-inline-bubble::after {
  content: '';
  position: absolute;
  right: -6px; top: 9px;
  border: 4px solid transparent;
  border-left-color: var(--blue-dark);
}

#cheat-banner {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 9999;
  padding: 8px 20px;
  text-align: center;
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: var(--black);
  border-bottom: 3px solid var(--yellow);
  box-shadow: 0 3px 0 #000;
  animation: banner-drop 0.25s cubic-bezier(0.17,0.89,0.32,1.28) both;
}
@keyframes banner-drop {
  from { transform: translateY(-100%); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

#board-area {
  padding: 10px 10px 6px; background: var(--blue-dark);
  border-left: 4px solid var(--yellow); border-right: 4px solid var(--yellow);
}

/* === MAIN LAYOUT: history panel + board side by side === */
#main-layout {
  display: flex;
  gap: 10px;
  align-items: flex-start;
}

/* === MOVE HISTORY PANEL === */
#move-history-panel {
  width: 160px;
  flex-shrink: 0;
  background: var(--black);
  border: 3px solid var(--yellow);
  box-shadow: 3px 3px 0 #000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  /* height will be set by JS to match board */
}

#move-history-header {
  background: var(--yellow);
  color: var(--black);
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-align: center;
  padding: 5px 8px;
  border-bottom: 2px solid #000;
  flex-shrink: 0;
}

#move-list {
  flex: 1;
  overflow-y: auto;
  padding: 4px 0;
  scroll-behavior: smooth;
}

#move-list::-webkit-scrollbar { width: 4px; }
#move-list::-webkit-scrollbar-track { background: #111; }
#move-list::-webkit-scrollbar-thumb { background: var(--yellow-dark); }

.move-row {
  display: grid;
  grid-template-columns: 28px 1fr 1fr;
  align-items: center;
  font-family: 'Courier Prime', Courier, monospace;
  font-size: 11px;
  border-bottom: 1px solid rgba(245,200,0,0.08);
}
.move-row:hover { background: rgba(245,200,0,0.06); }

.move-num {
  color: var(--yellow-dark);
  font-size: 10px;
  padding: 3px 0 3px 6px;
  font-weight: 700;
  line-height: 1;
  border-right: 1px solid rgba(245,200,0,0.15);
}

.move-cell {
  padding: 3px 4px;
  color: var(--cream);
  cursor: default;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
  font-size: 11px;
  transition: background 0.1s;
}
.move-cell:first-of-type { border-right: 1px solid rgba(245,200,0,0.08); }
.move-cell.latest {
  color: var(--yellow);
  font-weight: 700;
}
.move-cell.white-cell { color: #ddd; }
.move-cell.black-cell { color: #aaa; }

.move-cell .piece-glyph {
  display: inline-block;
  margin-right: 1px;
  font-size: 10px;
}

#move-history-footer {
  padding: 4px 6px;
  border-top: 1px solid rgba(245,200,0,0.2);
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 10px;
  color: rgba(245,200,0,0.5);
  text-align: center;
  flex-shrink: 0;
  letter-spacing: 0.05em;
}

#board-wrap { display: flex; gap: 4px; align-items: flex-start; }

#board-container { position: relative; display: inline-block; }

#board {
  display: grid; grid-template-columns: repeat(8, 1fr);
  border: 4px solid var(--yellow); box-shadow: 4px 4px 0 #000;
}

.sq {
  cursor: pointer; position: relative; user-select: none;
}
.sq.light { background: #cce0ff; }
.sq.dark  { background: #1a5fa8; }

.sq.selected { outline: 4px solid var(--yellow); outline-offset: -4px; z-index: 1; }

.sq.movable::after {
  content: ''; position: absolute; width: 32%; height: 32%; border-radius: 50%;
  background: rgba(245,200,0,0.7); box-shadow: 0 0 6px rgba(245,200,0,0.8);
  pointer-events: none; top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 2;
}
.sq.capture::after {
  content: ''; position: absolute; inset: 0;
  box-shadow: inset 0 0 0 5px rgba(245,200,0,0.8); pointer-events: none; z-index: 2;
}
.sq.check { background: #cc0000 !important; }
.sq.blocked-move::after {
  content: ''; position: absolute; inset: 3px; border-radius: 50%;
  border: 2px dashed rgba(200,60,40,0.5); pointer-events: none; z-index: 2;
}
.sq.explosion-sq { animation: explode-sq 0.4s ease-out forwards; }
@keyframes explode-sq {
  0%   { background: #ff4400 !important; }
  50%  { background: #ffaa00 !important; }
  100% { background: inherit; }
}
.sq.wall-sq {
  background: #7a3a1a !important;
  box-shadow: inset 0 0 0 2px #cc6633;
  cursor: default;
}

#piece-layer {
  position: absolute; top: 0; left: 0; pointer-events: none;
}

.piece {
  position: absolute; display: flex; align-items: center; justify-content: center;
  transition: left 0.17s cubic-bezier(0.3,0.8,0.3,1), top 0.17s cubic-bezier(0.3,0.8,0.3,1);
  will-change: left, top; z-index: 10; pointer-events: none;
}
.piece svg { width: 72%; height: 72%; display: block; }
.piece.moving { z-index: 20; }

@keyframes piece-lift {
  0%   { transform: scale(1) translateY(0); }
  50%  { transform: scale(1.13) translateY(-5px); }
  100% { transform: scale(1) translateY(0); }
}
.piece.moving { animation: piece-lift 0.17s ease-in-out; }

@keyframes capture-pop {
  0%   { transform: scale(1); opacity: 1; }
  50%  { transform: scale(1.4); opacity: 0.7; }
  100% { transform: scale(0); opacity: 0; }
}
.piece.capturing { animation: capture-pop 0.2s ease-in forwards; z-index: 9; }

#wall-overlay {
  display: none;
  position: absolute;
  left: 0; right: 0;
  z-index: 15;
  pointer-events: none;
  background: repeating-linear-gradient(
    90deg,
    #cc6633 0px, #cc6633 18px,
    #b85c2a 18px, #b85c2a 36px
  );
  border-top: 1px solid #7a3800;
  border-bottom: 1px solid #7a3800;
  box-shadow: 0 1px 4px rgba(0,0,0,0.5);
}
#wall-overlay.visible { display: block; }

/* B-2 Stealth Bomber */
#b2-bomber {
  display: none;
  position: absolute;
  z-index: 100;
  pointer-events: none;
  width: 0; height: 0;
}
#b2-bomber.flying {
  display: block;
  animation: b2-fly 3.5s cubic-bezier(0.2,0,0.8,1) forwards;
}
@keyframes b2-fly {
  0%   { transform: translateX(calc(100vw + 120px)) translateY(0px) scale(0.7); opacity: 0; }
  15%  { opacity: 1; }
  85%  { opacity: 1; }
  100% { transform: translateX(-120px) translateY(-30px) scale(0.9); opacity: 0; }
}
#b2-bomber svg {
  width: 90px;
  height: 45px;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.7));
}
@keyframes bomb-drop {
  0%   { transform: translateY(0) scale(1); opacity: 1; }
  60%  { transform: translateY(40px) scale(0.8); opacity: 0.8; }
  100% { transform: translateY(0) scale(2.5); opacity: 0; }
}
.bomb-flash {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #ffaa00 40%, #ff4400 70%, transparent 100%);
  animation: bomb-flash-anim 0.5s ease-out forwards;
  pointer-events: none;
  z-index: 50;
}
@keyframes bomb-flash-anim {
  0%   { transform: scale(0); opacity: 1; }
  50%  { transform: scale(1); opacity: 0.9; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* Don's Retaliation Tank */
#don-tank {
  display: none;
  position: absolute;
  z-index: 110;
  pointer-events: none;
}
#don-tank.rolling {
  display: block;
  animation: tank-roll 2.8s cubic-bezier(0.3,0,0.7,1) forwards;
}
@keyframes tank-roll {
  0%   { transform: translateX(calc(100% + 200px)); opacity:0; }
  10%  { opacity: 1; }
  45%  { transform: translateX(30%); }
  55%  { transform: translateX(30%); }
  90%  { opacity: 1; }
  100% { transform: translateX(calc(-100% - 200px)); opacity:0; }
}
@keyframes tank-shell {
  0%   { transform: scale(0); opacity:1; }
  60%  { transform: scale(1.8); opacity:0.8; }
  100% { transform: scale(3); opacity:0; }
}
.tank-explosion {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #ffdd00 30%, #ff6600 60%, transparent 100%);
  animation: tank-shell 0.45s ease-out forwards;
  pointer-events: none;
  z-index: 111;
}

#s-overlay {
  position: absolute; display: flex; align-items: center; justify-content: center;
  pointer-events: none; z-index: 5; overflow: hidden;
}
#s-letter {
  font-family: 'Cinzel Decorative', serif; font-weight: 700;
  text-shadow: 0 2px 8px rgba(0,0,0,0.35); line-height: 1; user-select: none;
}

#files { display: flex; margin-left: 18px; }
.file-label {
  text-align: center; font-family: 'EB Garamond', Georgia, serif;
  font-size: 11px; color: var(--yellow); padding-top: 3px; font-weight: 700; letter-spacing: 0.05em;
}
#ranks { display: flex; flex-direction: column; justify-content: space-around; }
.rank-label {
  font-family: 'EB Garamond', Georgia, serif; font-size: 11px; color: var(--yellow);
  width: 14px; text-align: right; font-weight: 700;
}

#controls-bar {
  width: 100%; background: var(--blue-dark);
  border: 4px solid var(--yellow); border-top: 3px solid var(--yellow-dark);
  padding: 8px 12px; display: flex; gap: 8px; align-items: center; justify-content: center;
  flex-wrap: wrap; box-shadow: 4px 4px 0 #000; margin-top: 4px;
}
button {
  font-family: 'EB Garamond', Georgia, serif; font-size: 13px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase; background: var(--yellow); color: var(--black);
  border: 3px solid #000; padding: 5px 14px; cursor: pointer; box-shadow: 3px 3px 0 #000; transition: all 0.08s;
}
button:hover { background: #fff; transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #000; }
button:active { transform: translate(2px,2px); box-shadow: 1px 1px 0 #000; }

#bot-row {
  width: 100%; background: var(--blue-dark);
  border: 4px solid var(--yellow); border-top: none;
  padding: 7px 12px; display: flex; align-items: center; justify-content: center; gap: 10px;
  position: relative; box-shadow: 4px 4px 0 #000;
}
.bot-label { font-family: 'EB Garamond', Georgia, serif; font-size: 13px; color: var(--yellow); letter-spacing: 0.15em; text-transform: uppercase; }
#bot-menu {
  display: none; position: absolute; bottom: 110%; left: 50%; transform: translateX(-50%); z-index: 99;
  background: var(--cream); border: 3px solid #000; box-shadow: 4px 4px 0 #000;
  min-width: 170px; max-height: 220px; overflow-y: auto;
}
#bot-buttons button {
  display: block; width: 100%; padding: 6px 14px; font-size: 13px; text-align: left;
  background: var(--cream); border: none; border-bottom: 2px solid #000;
  border-radius: 0; color: var(--black); box-shadow: none; letter-spacing: 0.02em;
  font-family: 'EB Garamond', Georgia, serif; font-weight: 600; text-transform: none;
}
#bot-buttons button:hover { background: var(--yellow); transform: none; box-shadow: none; }
#bot-buttons button.active-bot { background: var(--blue-dark); color: var(--yellow); }
#bot-buttons button.locked-bot { color: #888; font-style: italic; }
#bot-buttons button.locked-bot:hover { background: var(--cream); color: #888; cursor: default; }

#unlock-row {
  width: 100%; background: var(--black);
  border: 4px solid var(--yellow); border-top: none;
  padding: 7px 12px; display: flex; align-items: center; justify-content: center; gap: 8px;
  box-shadow: 4px 4px 0 #000;
}
.unlock-label {
  font-family: 'EB Garamond', Georgia, serif; font-size: 12px;
  color: rgba(245,200,0,0.6); letter-spacing: 0.12em; text-transform: uppercase;
  white-space: nowrap; flex-shrink: 0;
}
#unlock-input {
  font-family: 'Courier Prime', Courier, monospace;
  font-size: 13px; font-weight: 700; letter-spacing: 0.18em;
  background: #111; color: var(--yellow);
  border: 2px solid rgba(245,200,0,0.4);
  padding: 4px 10px; width: 140px;
  outline: none; text-transform: uppercase;
  box-shadow: inset 2px 2px 0 #000;
  transition: border-color 0.15s;
}
#unlock-input:focus { border-color: var(--yellow); }
#unlock-input.shake {
  animation: input-shake 0.3s ease;
  border-color: #cc0000;
}
#unlock-input.success {
  border-color: #00cc44;
  color: #00cc44;
}
@keyframes input-shake {
  0%,100% { transform: translateX(0); }
  20%      { transform: translateX(-5px); }
  40%      { transform: translateX(5px); }
  60%      { transform: translateX(-4px); }
  80%      { transform: translateX(4px); }
}
#unlock-btn {
  font-size: 12px; padding: 4px 10px;
  background: rgba(245,200,0,0.15); color: var(--yellow);
  border: 2px solid rgba(245,200,0,0.4);
  box-shadow: none; letter-spacing: 0.1em;
}
#unlock-btn:hover { background: var(--yellow); color: var(--black); transform: none; box-shadow: 2px 2px 0 #000; }

#picker {
  display: none; flex-direction: row; gap: 6px; padding: 6px 12px;
  background: var(--blue-dark); border-top: 2px solid var(--yellow-dark);
  justify-content: center; flex-wrap: wrap;
}
#s-color-bar {
  width: 100%; background: var(--black); border: 4px solid var(--yellow); border-top: none;
  padding: 6px 12px; display: flex; align-items: center; justify-content: center; gap: 10px;
  box-shadow: 4px 4px 0 #000;
}
.s-color-label { font-family: 'EB Garamond', Georgia, serif; font-size: 13px; color: var(--yellow); letter-spacing: 0.1em; text-transform: uppercase; }


@keyframes chat-pop {
  from { opacity: 0; transform: translateX(-10px) scale(0.95); }
  to   { opacity: 1; transform: translateX(0) scale(1); }
}
#game-over-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 20px;
  animation: overlay-fade-in 0.4s ease forwards;
}
#game-over-overlay.show { display: flex; }
#game-over-overlay.checkmate { background: rgba(160, 0, 0, 0.88); }
#game-over-overlay.win       { background: rgba(0, 130, 40, 0.88); }

@keyframes overlay-fade-in {
  from { opacity: 0; transform: scale(1.08); }
  to   { opacity: 1; transform: scale(1); }
}

#game-over-word {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: clamp(60px, 18vw, 160px);
  font-weight: 700;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: #fff;
  text-shadow: 6px 6px 0 rgba(0,0,0,0.4), -2px -2px 0 rgba(0,0,0,0.2);
  -webkit-text-stroke: 2px rgba(0,0,0,0.3);
  animation: word-pop 0.5s cubic-bezier(0.17, 0.89, 0.32, 1.28) 0.1s both;
  line-height: 1;
}

#game-over-sub {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: clamp(14px, 3vw, 22px);
  color: rgba(255,255,255,0.85);
  letter-spacing: 3px;
  text-transform: uppercase;
  animation: word-pop 0.5s cubic-bezier(0.17, 0.89, 0.32, 1.28) 0.2s both;
}

@keyframes word-pop {
  from { opacity: 0; transform: scale(0.6) translateY(20px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

#game-over-btn {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: #fff;
  color: #111;
  border: 4px solid #000;
  padding: 10px 30px;
  cursor: pointer;
  box-shadow: 5px 5px 0 rgba(0,0,0,0.4);
  transition: all 0.08s;
  animation: word-pop 0.5s cubic-bezier(0.17, 0.89, 0.32, 1.28) 0.35s both;
}
#game-over-btn:hover { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 rgba(0,0,0,0.4); }
#game-over-btn:active { transform: translate(2px,2px); box-shadow: 2px 2px 0 rgba(0,0,0,0.4); }
</style>
</head>
<body>

<div id="cheat-banner"></div>

<div id="game-over-overlay">
  <div id="game-over-word">CHECKMATE</div>
  <div id="game-over-sub">Better luck next time</div>
  <button id="game-over-btn" onclick="closeOverlayAndReset()">Play Again</button>
</div>

<div id="app">
  <div id="header">
    <h1>♟ STEVENSON CHESS</h1>
    <div class="header-sub">A Private Club for Steves · Est. 2026</div>
  </div>
  <div id="status-bar">
    <div id="status-left">
      <div id="status">White to move</div>
      <div id="msg"></div>
    </div>
    <div id="chat-inline">
      <div id="chat-inline-bubble"></div>
      <div id="chat-inline-avatar"></div>
    </div>
  </div>
  <div id="board-area">
    <div id="main-layout">
      <!-- MOVE HISTORY PANEL -->
      <div id="move-history-panel">
        <div id="move-history-header">📋 Move Log</div>
        <div id="move-list"></div>
        <div id="move-history-footer" id="move-count-footer">—</div>
      </div>

      <!-- BOARD SECTION -->
      <div id="board-wrap">
        <div id="ranks"></div>
        <div>
          <div id="board-container">
            <div id="board"></div>
            <div id="piece-layer"></div>
            <div id="wall-overlay"></div>
            <div id="b2-bomber"></div>
            <div id="don-tank"></div>
            <div id="s-overlay"><span id="s-letter">S</span></div>
          </div>
          <div id="files"></div>
        </div>
      </div>
    </div>
  </div>
  <div id="controls-bar">
    <button onclick="resetGame()">New Game</button>
